rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /TransactionDataBase/{document} {
      allow create: if request.auth.uid == request.resource.data.BuyerID;
      allow read: if request.auth.uid == resource.data.BuyerID;
      allow write: if request.auth.uid == resource.data.transactionId;
      allow delete: if false;
    }

    match /SavedAccountDetiles/{document} {
      allow create: if request.auth.uid == request.resource.data.userID;
      allow read: if request.auth.uid == resource.data.userID;
      allow write: if request.auth.uid == resource.data.userID;
      allow delete: if false;
    }

    match /users/{document} {
      allow create: if request.auth.uid == request.resource.data.email;
      allow read: if request.auth.uid == resource.data.email;
      allow write: if request.auth.uid == resource.data.email;
      allow delete: if false;
    }

    match /users/{parent}/paymentMethods/{document} {
      allow create: if request.auth.uid == parent;
      allow read: if request.auth.uid == parent;
      allow write: if request.auth.uid == parent;
      allow delete: if request.auth.uid == parent;
    }
  }
}
